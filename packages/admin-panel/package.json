{
  "name": "@claude-ws/admin-panel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Admin Panel for Docker Pool Management",
  "scripts": {
    "predev": "lsof -ti:8053 | xargs kill -9 2>/dev/null || true && rm -rf .next || true",
    "dev": "NODE_ENV=development node --import tsx/esm src/server.ts",
    "start": "NODE_ENV=production node --import tsx/esm src/server.ts",
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockerode": "^4.0.9",
    "drizzle-orm": "^0.45.1",
    "better-sqlite3": "^12.6.2",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
